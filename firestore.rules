
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Utility functions for security and ownership
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // User profile and subcollection hierarchy
    match /users/{userId} {
      // Grant full authority to the owner for their own profile document
      // Using 'write' to explicitly include 'delete' permissions
      allow read, write: if isOwner(userId);
      
      // Recursively grant full authority to the owner for all nested telemetry and records
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
