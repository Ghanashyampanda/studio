rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * HeatGuard AI Security Rules
     * 
     * Core Philosophy:
     * This ruleset enforces a strict user-ownership model where all health and personal data
     * is siloed by the user's Firebase Authentication UID. Authorization is primarily
     * path-based to ensure high performance and absolute data privacy.
     * 
     * Data Structure:
     * All sensitive entities (Vitals, Risk Assessments, Emergency Contacts) are stored as
     * subcollections under the primary /users/{userId} document. This creates a clear
     * security boundary for each user.
     * 
     * Key Security Decisions:
     * 1. Path-Based Authorization: By nesting data under {userId}, we compare request.auth.uid
     *    directly against the path segment, avoiding expensive get() calls.
     * 2. Prototyping Mode: Rules strictly enforce 'who' can access data (Authorization)
     *    but remain flexible on 'what' the data looks like (Schema) to allow rapid iteration.
     * 3. Relational Integrity: On creation, the rules force internal 'userId' fields to
     *    match the authenticated user's ID, ensuring denormalized data remains consistent.
     * 4. Admin Access: An optional top-level 'roles_admin' collection allows for global
     *    monitoring capabilities based on document existence.
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for UserProfile. Users can only manage their own profile.
     * @path /users/{userId}
     * @allow (create) if auth.uid matches userId.
     * @deny (update) if user attempts to change their document ID.
     * @principle Ownership and Self-Creation.
     */
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      /**
       * @description Rules for Emergency Contacts. Private to the user.
       * @path /users/{userId}/emergency_contacts/{contactId}
       * @allow (list) if request.auth.uid == userId.
       * @deny (create) if internal userId field doesn't match the path.
       * @principle Structural Segregation and Path-Based Ownership.
       */
      match /emergency_contacts/{contactId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Rules for VitalSignData. Highly sensitive health data.
       * @path /users/{userId}/vital_sign_data/{vitalSignDataId}
       * @allow (get) if the owner is requesting their own vitals.
       * @deny (delete) if the document does not exist.
       * @principle Verified Identity and Robustness for State Changes.
       */
      match /vital_sign_data/{vitalSignDataId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Rules for RiskAssessments. AI-generated results for the user.
       * @path /users/{userId}/risk_assessments/{assessmentId}
       * @allow (create) if the user is authenticated and is the owner of the path.
       * @deny (update) if trying to modify the userId field.
       * @principle Relational Integrity and Ownership.
       */
      match /risk_assessments/{assessmentId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Rules for UserSettings. Configuration for alerts and preferences.
       * @path /users/{userId}/user_settings/current
       * @allow (get) if the user is fetching their own 'current' settings.
       * @deny (create) if internal userId field is missing or incorrect.
       * @principle Path-based ownership for singleton documents.
       */
      match /user_settings/current {
        allow get: if isOwner(userId) || isAdmin();
        allow list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Rules for AlertHistory. Log of previous emergencies.
       * @path /users/{userId}/alert_history/{alertId}
       * @allow (list) if the user is viewing their history.
       * @deny (write) if the user is not authenticated.
       * @principle Query Against Paths (QAPs).
       */
      match /alert_history/{alertId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Rules for AIHealthTip. Educational content personalized for the user.
       * @path /users/{userId}/ai_health_tips/{tipId}
       * @allow (update) if the user marks a tip as 'read'.
       * @deny (list) if a different user tries to access this path.
       * @principle Path-based Ownership.
       */
      match /ai_health_tips/{tipId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }
    }

    /**
     * @description Admin Role Management. Controls which users have monitoring privileges.
     * @path /roles_admin/{adminUid}
     * @allow (get) for signed-in users to check their own role status.
     * @deny (write) for all standard users.
     * @principle Roles and Access Modeling.
     */
    match /roles_admin/{adminUid} {
      allow get: if isSignedIn() && (request.auth.uid == adminUid || isAdmin());
      allow list: if isAdmin();
      allow create, update, delete: if false; // Admin roles are typically managed manually or via cloud functions.
    }
  }
}