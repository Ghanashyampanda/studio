{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile information.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email"]
    },
    "Habit": {
      "title": "Habit",
      "type": "object",
      "description": "A health-related habit to track regularly.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "streak": { "type": "number" },
        "lastCheckInDate": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "title"]
    },
    "Task": {
      "title": "Task",
      "type": "object",
      "description": "A one-time daily task or to-do.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "completed": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "title", "completed"]
    },
    "EmergencyContact": {
      "title": "EmergencyContact",
      "type": "object",
      "description": "Stores info about an emergency contact.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "isPrimary": { "type": "boolean" }
      },
      "required": ["id", "userId", "name", "phoneNumber"]
    },
    "VitalSignData": {
      "title": "VitalSignData",
      "type": "object",
      "description": "Records vital signs data.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "bodyTemperatureC": { "type": "number" },
        "heartRateBpm": { "type": "number" }
      },
      "required": ["id", "userId", "timestamp", "bodyTemperatureC", "heartRateBpm"]
    }
  },
  "auth": {
    "providers": ["password", "google"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "User profile document."
    },
    "/users/{userId}/habits/{habitId}": {
      "schema": { "$ref": "#/backend/entities/Habit" },
      "description": "User health habits tracker."
    },
    "/users/{userId}/tasks/{taskId}": {
      "schema": { "$ref": "#/backend/entities/Task" },
      "description": "User daily one-time tasks."
    },
    "/users/{userId}/emergency_contacts/{contactId}": {
      "schema": { "$ref": "#/backend/entities/EmergencyContact" },
      "description": "Emergency responder nodes."
    },
    "/users/{userId}/vital_sign_data/{vitalsId}": {
      "schema": { "$ref": "#/backend/entities/VitalSignData" },
      "description": "Historical biometric telemetry records."
    },
    "/users/{userId}/user_settings/{settingId}": {
      "schema": { "type": "object" },
      "description": "User configuration and alert thresholds."
    },
    "/users/{userId}/alert_history/{alertId}": {
      "schema": { "type": "object" },
      "description": "Audit log of triggered rescue events."
    }
  }
}