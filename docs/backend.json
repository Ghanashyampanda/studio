
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile information.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email"]
    },
    "Habit": {
      "title": "Habit",
      "type": "object",
      "description": "A health-related habit to track regularly.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "streak": { "type": "number" },
        "lastCheckInDate": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "title"]
    },
    "Task": {
      "title": "Task",
      "type": "object",
      "description": "A one-time daily task or to-do.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "completed": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "title", "completed"]
    },
    "EmergencyContact": {
      "title": "EmergencyContact",
      "type": "object",
      "description": "Stores info about an emergency contact.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "isPrimary": { "type": "boolean" }
      },
      "required": ["id", "userId", "name", "phoneNumber"]
    },
    "VitalSignData": {
      "title": "VitalSignData",
      "type": "object",
      "description": "Records vital signs data.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "bodyTemperatureC": { "type": "number" },
        "heartRateBpm": { "type": "number" }
      },
      "required": ["id", "userId", "timestamp", "bodyTemperatureC", "heartRateBpm"]
    }
  },
  "auth": {
    "providers": ["password", "google"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "User profile document."
        }
      },
      {
        "path": "/users/{userId}/habits/{habitId}",
        "definition": {
          "entityName": "Habit",
          "schema": { "$ref": "#/backend/entities/Habit" },
          "description": "User health habits."
        }
      },
      {
        "path": "/users/{userId}/tasks/{taskId}",
        "definition": {
          "entityName": "Task",
          "schema": { "$ref": "#/backend/entities/Task" },
          "description": "User daily tasks."
        }
      },
      {
        "path": "/users/{userId}/emergency_contacts/{contactId}",
        "definition": {
          "entityName": "EmergencyContact",
          "schema": { "$ref": "#/backend/entities/EmergencyContact" },
          "description": "Emergency contacts."
        }
      },
      {
        "path": "/users/{userId}/vital_sign_data/{vitalsId}",
        "definition": {
          "entityName": "VitalSignData",
          "schema": { "$ref": "#/backend/entities/VitalSignData" },
          "description": "Vitals telemetry."
        }
      }
    ]
  }
}
