
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile information.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email"]
    },
    "Habit": {
      "title": "Habit",
      "type": "object",
      "description": "A health-related habit to track regularly.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "streak": { "type": "number" },
        "lastCheckInDate": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "title"]
    },
    "Task": {
      "title": "Task",
      "type": "object",
      "description": "A one-time daily task or to-do.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "completed": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "title", "completed"]
    },
    "EmergencyContact": {
      "title": "EmergencyContact",
      "type": "object",
      "description": "Stores info about an emergency contact.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "isPrimary": { "type": "boolean" }
      },
      "required": ["id", "userId", "name", "phoneNumber"]
    },
    "VitalSignData": {
      "title": "VitalSignData",
      "type": "object",
      "description": "Records vital signs and environmental telemetry.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "bodyTemperatureC": { "type": "number" },
        "heartRateBPM": { "type": "number" },
        "outsideTemperatureC": { "type": "number" },
        "pulseFrequencyBPM": { "type": "number" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "aiVerdict": { "type": "string" }
      },
      "required": ["id", "userId", "timestamp", "bodyTemperatureC", "heartRateBPM", "outsideTemperatureC", "latitude", "longitude"]
    },
    "AIMetrics": {
      "title": "AIMetrics",
      "type": "object",
      "description": "Metadata for the self-learning AI model performance.",
      "properties": {
        "lastTrained": { "type": "string", "format": "date-time" },
        "datasetSize": { "type": "number" },
        "currentAccuracy": { "type": "number" },
        "modelStatus": { "type": "string", "enum": ["Ready", "Training"] }
      }
    },
    "AccuracyRecord": {
      "title": "AccuracyRecord",
      "type": "object",
      "description": "Historical accuracy data point for charting.",
      "properties": {
        "accuracy": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "google"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "User profile document."
    },
    "/users/{userId}/habits/{habitId}": {
      "schema": { "$ref": "#/backend/entities/Habit" },
      "description": "User health habits tracker."
    },
    "/users/{userId}/tasks/{taskId}": {
      "schema": { "$ref": "#/backend/entities/Task" },
      "description": "User daily one-time tasks."
    },
    "/users/{userId}/emergency_contacts/{contactId}": {
      "schema": { "$ref": "#/backend/entities/EmergencyContact" },
      "description": "Emergency responder nodes."
    },
    "/users/{userId}/vital_sign_data/{vitalsId}": {
      "schema": { "$ref": "#/backend/entities/VitalSignData" },
      "description": "Historical biometric telemetry records."
    },
    "/users/{userId}/ai_metrics/current": {
      "schema": { "$ref": "#/backend/entities/AIMetrics" },
      "description": "Active AI model performance metrics."
    },
    "/users/{userId}/ai_accuracy_history/{historyId}": {
      "schema": { "$ref": "#/backend/entities/AccuracyRecord" },
      "description": "Time-series data for AI accuracy visualization."
    }
  }
}
